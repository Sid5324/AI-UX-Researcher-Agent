# =================================================================
# AI UX RESEARCHER AGENT - ENVIRONMENT CONFIGURATION
# =================================================================
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------
APP_NAME="AI UX Researcher Agent"
APP_MODE=demo  # demo or production
DEBUG=False
LOG_LEVEL=INFO

# -----------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# -----------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/agentic_research.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentic_research

# -----------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# -----------------------------------------------------------------
# LLM CONFIGURATION
# -----------------------------------------------------------------
# Primary: Ollama (local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# Fallback: OpenRouter (requires API key)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Fallback: Google Gemini (requires API key)
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Fallback: Anthropic Claude (requires API key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------
# VECTOR DATABASE (ChromaDB)
# -----------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=./data/chromadb
CHROMA_COLLECTION_NAME=agentic_research_memory

# -----------------------------------------------------------------
# REDIS CACHE (optional)
# -----------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=False

# -----------------------------------------------------------------
# DATA CONNECTORS (all optional for demo mode)
# -----------------------------------------------------------------

# PostHog Analytics
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://app.posthog.com

# Google Analytics 4 (BigQuery)
GA4_PROJECT_ID=
GA4_DATASET=analytics_123456789
GOOGLE_CREDENTIALS_PATH=

# Kaggle Datasets
KAGGLE_USERNAME=
KAGGLE_KEY=

# User Interviews
USER_INTERVIEWS_API_KEY=

# -----------------------------------------------------------------
# NOTIFICATION SERVICES (optional)
# -----------------------------------------------------------------

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TLS=True

# Slack
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# -----------------------------------------------------------------
# FRONTEND CONFIGURATION
# -----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
