# ==========================================
# Agentic Research AI - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values

# ===================
# Application
# ===================
APP_MODE=demo                    # "demo" (synthetic data) or "real" (actual APIs)
DEBUG=false
ENVIRONMENT=development

# ===================
# Database
# ===================
DATABASE_URL=sqlite+aiosqlite:///./data/agentic_research.db
USE_SUPABASE=false
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=your_anon_or_service_key

# ===================
# Ollama (Local LLM) - Required
# ===================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_FALLBACK_MODELS=qwen2.5-coder:7b,deepseek-r1:8b
OLLAMA_TIMEOUT=120

# ===================
# Cloud LLMs (Optional - for fallback)
# ===================
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...

# ===================
# Analytics APIs (Real Mode Only)
# ===================
# PostHog (free tier available)
# POSTHOG_API_KEY=phc_...
# POSTHOG_PROJECT_ID=12345

# Google Analytics 4 via BigQuery (free public dataset)
# GA4_PROJECT_ID=your-gcp-project
# GA4_DATASET=analytics_123456789

# Kaggle Datasets (optional)
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key

# ===================
# Memory & Storage
# ===================
CHROMADB_PATH=./data/chromadb
USE_REDIS=false
# REDIS_URL=redis://localhost:6379/0

# ===================
# Observability (Optional)
# ===================
ENABLE_TRACING=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ===================
# API Server
# ===================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===================
# Agent Behavior
# ===================
MAX_REACT_ITERATIONS=10
CHECKPOINT_FREQUENCY=medium      # none/low/medium/high
AUTONOMOUS_MODE=supervised       # supervised/partial/full

# ===================
# File Upload Limits
# ===================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=.csv,.xlsx,.xls,.json

# ==========================================
# Setup Instructions
# ==========================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. For Demo Mode (No API keys needed):
#    - Keep APP_MODE=demo
#    - Ensure Ollama is running: curl http://localhost:11434/api/tags
#    - Pull models: ollama pull llama3.2:3b
#
# 3. For Real Mode (Connect to actual APIs):
#    - Set APP_MODE=real
#    - Add at least one analytics API key (PostHog or GA4)
#    - Optional: Add Kaggle, OpenRouter keys for more features
#
# 4. Run the application:
#    uvicorn src.api.main:app --reload
#
# ==========================================
