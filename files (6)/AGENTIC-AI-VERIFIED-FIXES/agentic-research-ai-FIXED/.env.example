# ==============================================
# Agentic Research AI - Environment Configuration
# ==============================================

# Application Settings
APP_NAME="Agentic Research AI"
APP_MODE=demo  # demo or production
DEBUG=False

# Database Configuration
POSTGRES_DB=agentic_research
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://postgres:change-me-in-production@postgres:5432/agentic_research

# AI Model Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Cloud AI APIs (Optional)
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Authentication
# Generate secure key: openssl rand -hex 32
JWT_SECRET_KEY=generate-a-secure-random-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Analytics (Optional)
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# Redis (Optional)
REDIS_URL=redis://redis:6379/0

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=INFO
